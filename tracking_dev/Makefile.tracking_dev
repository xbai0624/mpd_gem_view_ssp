tracking_dev.pro:
../../../apps/qt-6.10.1/qtbase/lib/QtWidgets.framework/Resources/QtWidgets.prl:
../../../apps/qt-6.10.1/qtbase/lib/QtGui.framework/Resources/QtGui.prl:
../../../apps/qt-6.10.1/qtbase/lib/QtCore.framework/Resources/QtCore.prl:
qmake: FORCE
	@$(QMAKE) -o Makefile.tracking_dev tracking_dev.pro

qmake_all: FORCE


all: Makefile.tracking_dev lib/libtracking_dev.1.0.0.dylib

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../../apps/qt-6.10.1/qtbase/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents include/VirtualDetector.h include/CoordSystem.h include/Detector2DHitItem.h include/Detector2DHitView.h include/IsometricView.h include/histos.hpp include/Tracking.h include/tracking_struct.h include/TrackingDataHandler.h include/TrackingUtility.h include/TrackingConfigWidget.h include/TrackingResultPanel.h ../gui/include/HistoItem.h ../gui/include/HistoItem2D.h include/Viewer.h $(DISTDIR)/
	$(COPY_FILE) --parents src/VirtualDetector.cpp src/CoordSystem.cpp src/Detector2DHitItem.cpp src/Detector2DHitView.cpp src/IsometricView.cpp src/TrackingConfigWidget.cpp src/TrackingResultPanel.cpp ../gui/src/HistoItem.cpp ../gui/src/HistoItem2D.cpp src/Tracking.cpp src/tracking_struct.cpp src/TrackingDataHandler.cpp src/TrackingUtility.cpp src/Viewer.cpp $(DISTDIR)/


clean: compiler_clean 
	-$(DEL_FILE) $(OBJECTS)
	-$(DEL_FILE) *~ core *.core


distclean: clean 
	-$(DEL_FILE) lib/$(TARGET) 
	-$(DEL_FILE) lib/$(TARGET0) lib/$(TARGET1) lib/$(TARGET2) $(TARGETA)
	-$(DEL_FILE) Makefile.tracking_dev


####### Sub-libraries

xcodeproj:
	@$(QMAKE) -spec macx-xcode "$(EXPORT__PRO_FILE_)"

mocclean: compiler_moc_header_clean compiler_moc_objc_header_clean compiler_moc_source_clean

mocables: compiler_moc_header_make_all compiler_moc_objc_header_make_all compiler_moc_source_make_all

check: first

benchmark: first

compiler_rcc_make_all:
compiler_rcc_clean:
compiler_moc_predefs_make_all: moc/moc_predefs.h
compiler_moc_predefs_clean:
